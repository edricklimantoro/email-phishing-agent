              "value": "json"
            },
            {
              "name": "messages",
              "value": "={{[{\"role\":\"system\",\"content\":\"You are an email security classifier. Analyze the email and determine if it is phishing or safe. Respond with JSON: {\\\"classification\\\":\\\"phishing\\\"|\\\"safe\\\", \\\"confidence\\\":0.0-1.0}\"},{\"role\":\"user\",\"content\":\"Email:\\n```\\n\" + $json.body_text + \"\\n```\"}]}}"
