      "id": "cb7a6fca-aae2-4722-bdf4-62b2b0dd5eec",
      "name": "LLM Classifier",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        16,
        192
      ]
    },
    {
      "parameters": {
        "functionCode": "const items = $input.all();\nfor (const item of items) {\n  const raw = item.json.message?.content || '{}';\n  let parsed = {};\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    parsed = { classification: 'safe', confidence: 0 };\n  }\n  item.json.classification = parsed.classification || 'safe';\n  item.json.confidence = parsed.confidence || 0;\n  item.json.status = item.json.classification;\n}\nreturn items;"
      },
      "id": "ccd413e8-b9dd-45ad-a741-4669a6fbbf87",
      "name": "Parse LLM Response",
      "type": "n8n-nodes-base.function",
