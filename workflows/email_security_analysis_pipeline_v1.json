      "id": "660c6bc8-ceaf-4a93-86be-13720bb987b0",
      "name": "Store Classification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        464,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst processed = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const json = items[i].json;\n  \n  let cleanText = \"\";\n\n  // 1. If Google provided the 'text' field, use it directly without stripping tags\n  if (json.text) {\n    // Just normalize the spaces/newlines to keep the payload clean\n    cleanText = json.text.replace(/\\s+/g, ' ').trim();\n  } \n  // 2. Fallback: If there is ONLY HTML available, then we strip the tags\n  else if (json.textAsHtml || json.html) {\n    const rawHtml = json.textAsHtml || json.html;\n    cleanText = rawHtml.replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim();\n  } \n  // 3. Absolute fallback\n  else {\n    cleanText = json.snippet || '';\n  }\n  \n  // Safely extract the sender's email address\n  let senderEmail = 'unknown@sender.com';\n  if (json.from && json.from.value && json.from.value.length > 0) {\n    senderEmail = json.from.value[0].address;\n  } else if (json.from && json.from.text) {\n    senderEmail = json.from.text;\n  }\n\n  // Combine metadata WITH the body for the LLM to analyze contextually\n  const analysisPayload = `SENDER: ${senderEmail}\\nSUBJECT: ${json.subject || '(No Subject)'}\\n\\nBODY:\\n${cleanText}`;\n\n  processed.push({\n    json: {\n      message_id: json.id || json.messageId || `email-${Date.now()}-${i}`,\n      sender_email: senderEmail,\n      subject: json.subject || '(No Subject)',\n      body_text: analysisPayload \n    }\n  });\n}\n\nreturn processed;"
      },
